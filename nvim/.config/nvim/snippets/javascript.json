        ]
    },
    "ctime": {
        "prefix": "ctime",
        "description": "console.time ... console.timeEnd",
        "body": [
        "console.time(\"${1:label}\");",
        "${0:${TM_SELECTED_TEXT}}",
        "console.timeEnd(\"$1\");"
        ]
    },
    "ctimestamp": {
        "prefix": "ctimestamp",
