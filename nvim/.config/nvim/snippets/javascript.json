{
    "fun": {
        "prefix": "fun",
        "description": "function ...(...){...}",
        "body": [
        "function ${1:function_name}(${2}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "fun(": {
        "prefix": "fun(",
		"description": "(function(...) {...}(...))",
        "body": [
        "(function(${1}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}(${2}));"
        ]
    },
    "fun:": {
        "prefix": "fun:",
        "description": "...: function(...) {...}",
        "body": [
        "${1:method_name}: function (${2:attribute}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "},"
        ]
    },
    "funv": {
        "prefix": "funv",
        "description": "var ... = function (...) {...}",
        "body": [
        "var ${1:function_name} = function(${2}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "};"
        ]
    },
    "if": {
        "prefix": "if",
        "description": "if (...) {...}",
        "body": [
        "if (${1:true}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ife": {
        "prefix": "ife",
        "description": "if (...) {...} else {...}",
        "body": [
        "if (${1:true}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} else {",
        "    ${2}",
        "}"
        ]
    },
    "ter": {
        "prefix": "ter",
        "description": "... ? ... : ...",
        "body": [
        "${1:/* condition */} ? ${2:/* if true */} : ${0:/* if false */}"
        ]
    },
    "switch": {
        "prefix": "switch",
        "description": "switch",
        "body": [
        "switch (${1:expression}) {",
        "    case '${3:case}':",
        "        ${4}",
        "        break;",
        "    ${0}",
        "    default:",
        "        ${2}",
        "}"
        ]
    },
    "case": {
        "prefix": "case",
        "description": "case 'xyz': ... break",
        "body": [
        "case '${1:case}':",
        "    ${0:${TM_SELECTED_TEXT}}",
        "    break;"
        ]
    },
    "try": {
        "prefix": "try",
        "description": "try { ... } catch(e) { ... }",
        "body": [
        "try {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} catch (${1:e}) {",
        "    ${2:/* handle error */}",
        "}"
        ]
    },
    "tryf": {
        "prefix": "tryf",
        "description": "try { ... } catch(e) { ... } finally { ... }",
        "body": [
        "try {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} catch (${1:e}) {",
        "    ${2:/* handle error */}",
        "} finally {",
        "    ${3:/* be executed regardless of the try / catch result*/}",
        "}"
        ]
    },
    "terr": {
        "prefix": "terr",
        "description": "terr",
        "body": [
        "throw new Error('${1:error message}')"
        ]
    },
    "ret": {
        "prefix": "ret",
        "description": "ret",
        "body": [
        "return ${0:result};"
        ]
    },
    "for": {
        "prefix": "for",
        "description": "for (...) {...}",
        "body": [
        "for (var ${1:i} = 0, ${2:len} = ${3:Things.length}; $1 < $2; $1++) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "forr": {
        "prefix": "forr",
        "description": "reversed for (...) {...}",
        "body": [
        "for (var ${2:i} = ${1:Things.length} - 1; $2 >= 0; $2--) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "wh": {
        "prefix": "wh",
        "description": "(condition) { ... }",
        "body": [
        "while (${1:/* condition */}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "do": {
        "prefix": "do",
        "description": "do { ... } while (condition)",
        "body": [
        "do {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} while (${1:/* condition */});"
        ]
    },
    "fori": {
        "prefix": "fori",
        "description": "fori",
        "body": [
        "for (var ${1:prop} in ${2:object}) {",
        "    ${0:$2[$1]}",
        "}"
        ]
    },
    "has": {
        "prefix": "has",
        "description": "has",
        "body": [
        "hasOwnProperty(${0})"
        ]
    },
    "cl": {
        "prefix": "cl",
        "description": "console.log",
        "body": [
        "console.log(${0});"
        ]
    },
    "cd": {
        "prefix": "cd",
