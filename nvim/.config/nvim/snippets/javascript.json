    },
    "ctable": {
        "prefix": "ctable",
        "description": "console.table",
        "body": [
        "console.table(${1:\"${2:value}\"});"
        ]
    },
    "us": {
        "prefix": "us",
        "description": "us",
        "body": [
        "'use strict';"
        ]
    },
    "timeout": {
        "prefix": "timeout",
        "description": "timeout",
        "body": [
        "setTimeout(function () {${0}}${2}, ${1:10});"
        ]
    },
    "const": {
        "prefix": "const",
        "description": "const",
