{
    "#!": {
        "prefix": "#!",
        "description": "#!",
        "body": [
        "#!/usr/bin/env lua",
        "$1"
        ]
    },
    "local": {
        "prefix": "local",
        "description": "local",
        "body": [
        "local ${1:x} = ${0:1}"
        ]
    },
    "fun": {
        "prefix": "fun",
        "description": "fun",
        "body": [
        "function ${1:fname}(${2:...})",
        "    ${0:-- body}",
        "end"
        ]
    },
    "for": {
        "prefix": "for",
        "description": "for",
        "body": [
        "for ${1:i}=${2:1},${3:10} do",
        "    ${0:print(i)}",
        "end"
        ]
    },
    "forp": {
        "prefix": "forp",
        "description": "forp",
        "body": [
        "for ${1:i},${2:v} in pairs(${3:table_name}) do",
        "    ${0:-- body}",
        "end"
        ]
    },
    "fori": {
        "prefix": "fori",
        "description": "fori",
        "body": [
        "for ${1:i},${2:v} in ipairs(${3:table_name}) do",
        "    ${0:-- body}",
        "end"
        ]
    },
    "if": {
        "prefix": "if",
        "description": "if",
        "body": [
        "if ${1:condition} then",
        "    ${2:-- body}",
        "end"
        ]
    },
    "ife": {
        "prefix": "ife",
        "description": "ife",
        "body": [
        "if ${1:condition} then",
        "    ${2:-- if condition}",
        "else",
        "    ${0:-- else}",
        "end"
        ]
    },
    "elif": {
        "prefix": "elif",
        "description": "elif",
        "body": [
        "elseif ${1:condition} then",
        "    ${0:--body}"
        ]
    },
    "repeat": {
        "prefix": "repeat",
        "description": "repeat",
        "body": [
        "repeat",
        "    ${1:--body}",
        "until ${0:condition}"
        ]
    },
    "while": {
        "prefix": "while",
        "description": "while",
        "body": [
        "while ${1:condition} do",
        "    ${0:--body}",
        "end"
        ]
    },
    "print": {
        "prefix": "print",
        "description": "print",
        "body": [
        "print(\"${1:string}\")"
        ]
    },
    "im": {
        "prefix": "im",
        "description": "im",
        "body": [
        "import \"${1:import file}\""        ]
    }
}
