{
    "#!": {
        "prefix": "#!",
        "description": "#!",
        "body": [
        "#!/usr/bin/env node"
        ]
    },
    "ex": {
        "prefix": "ex",
        "description": "ex",
        "body": [
        "module.exports = ${1};"
        ]
    },
    "re": {
        "prefix": "re",
        "description": "re",
        "body": [
        "${1:const} ${2} = require('${3:module_name}');"
        ]
    },
    "on": {
        "prefix": "on",
        "description": "on",
        "body": [
        "on('${1:event_name}', function(${2:stream}) {",
        "  ${3}",
        "});"
        ]
    },
    "emit": {
        "prefix": "emit",
        "description": "emit",
        "body": [
        "emit('${1:event_name}', ${2:args});"
        ]
    },
    "once": {
        "prefix": "once",
        "description": "once",
        "body": [
        "once('${1:event_name}', function(${2:stream}) {",
        "  ${3}",
        "});"
        ]
    },
    "http": {
        "prefix": "http",
        "description": "http",
        "body": [
        "http.createServer(${1:handler}).listen(${2:port_number});"
        ]
    },
    "net": {
        "prefix": "net",
        "description": "net",
        "body": [
        "net.createServer(function(${1:socket}){",
        "    ${1}.on('data', function('data'){",
        "      ${2}",
        "    ]});",
        "    ${1}.on('end', function(){",
        "      ${3}",
        "    });",
        "}).listen(${4:8124});"
        ]
    },
    "pipe": {
        "prefix": "pipe",
        "description": "pipe",
        "body": [
        "pipe(${1:stream})${2}"
        ]
    },
    "eget": {
        "prefix": "eget",
        "description": "eget",
        "body": [
        "${1:app}.get('${2:route}', ${3:handler});"
        ]
    },
    "epost": {
        "prefix": "epost",
        "description": "epost",
        "body": [
        "${1:app}.post('${2:route}', ${3:handler});"
        ]
    },
    "eput": {
        "prefix": "eput",
        "description": "eput",
        "body": [
        "${1:app}.put('${2:route}', ${3:handler});"
        ]
    },
    "edel": {
        "prefix": "edel",
        "description": "edel",
        "body": [
        "${1:app}.delete('${2:route}', ${3:handler});"
        ]
    },
    "stdin": {
        "prefix": "stdin",
        "description": "stdin",
        "body": [
        "process.stdin"
        ]
    },
    "stdout": {
        "prefix": "stdout",
        "description": "stdout",
        "body": [
        "process.stdout"
        ]
    },
    "stderr": {
        "prefix": "stderr",
        "description": "stderr",
        "body": [
        "process.stderr"        ]
    }
}
