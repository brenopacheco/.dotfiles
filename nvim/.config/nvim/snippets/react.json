{
    "import-react": {
        "prefix": "import-react",
        "description": "import React",
        "body": [
        "import React, { Component, useState } from 'react';",
        "import ReactDOM from 'react-dom';"
        ]
    },
    "set-state": {
        "prefix": "set-state",
        "description": "setState({...})",
        "body": [
        "this.setState({",
        "    ${0}",
        "});"
        ]
    },
    "state": {
        "prefix": "state",
        "description": "setState({...})",
        "body": [
        "        this.state = {",
        "            ${2}",
        "        }"
        ]
    },
    "comp": {
        "prefix": "comp",
        "description": "class ... extends Component {...}",
        "body": [
        "class ${1:ClassName} extends Component {",
        "    constructor() {",
        "        super();",
        "        this.state = {",
        "            ${2}",
        "        }",
        "    }",
        "    render() {",
        "        return (",
        "            <>${3}</>",
        "                ${3}",
        "            </>",
        "        );",
        "    };",
        "};"
        ]
    },
    "compf": {
        "prefix": "compf",
        "description": "function(props) { ...JSX }",
        "body": [
        "function ${1:ComponentName}(${2:props}) {",
        "    const [${3:var}, ${4:set}] = useState(${5:0});",
        "    return (",
        "        <>",
        "            ${6}",
        "        </>",
        "    );",
        "};"
        ]
    },
    "compa": {
        "prefix": "acomp",
        "description": "const ... = () => JSX",
        "body": [
        "const ${1:ComponentName} = (${2:props}) => {",
        "    ${3:state}",
        "    return (",
        "        <>",
        "            ${4}",
        "        </>",
        "    );",
        "};"
        ]
    },
    "render": {
        "prefix": "render",
        "description": "render() {...}",
        "body": [
        "render() {",
        "    return (",
        "        <>",
        "            ${2}",
        "        </>",
        "    );",
        "}"
        ]
    },
    "rett": {
        "prefix": "rett",
        "description": "return( ...JSX )",
        "body": [
        "    return (",
        "            ${2}",
        "    );"
        ]
    },
    "componentDidMount": {
        "prefix": "componentDidMount",
        "description": "componentDidMount",
        "body": [
        "componentDidMount() {",
        "    ${1}",
        "};"
        ]
    },
    "componentDidUpdate": {
        "prefix": "componentDidUpdate",
        "description": "componentDidUpdate",
        "body": [
        "componentDidUpdate(prevProps, prevState) {",
        "    ${1}",
        "};"
        ]
    },
    "componentWillMount": {
        "prefix": "componentWillMount",
        "description": "componentWillMount",
        "body": [
        "componentWillMount() {",
        "    ${1}",
        "};"
        ]
    },
    "componentWillReceiveProps": {
        "prefix": "componentWillReceiveProps",
        "description": "componentWillReceiveProps",
        "body": [
        "componentWillReceiveProps(nextProps) {",
        "    ${1}",
        "};"
        ]
    },
    "componentWillUnmount": {
        "prefix": "componentWillUnmount",
        "description": "componentWillUnmount",
        "body": [
        "componentWillUnmount() {",
        "    ${1}",
        "};"
        ]
    },
    "componentWillUpdate": {
        "prefix": "componentWillUpdate",
        "description": "componentWillUpdate",
        "body": [
        "componentWillUpdate(nextProps, nextState) {",
        "    ${1}",
        "};"
        ]
    },
    "componentShouldUpdate": {
        "prefix": "componentShouldUpdate",
        "description": "shouldComponentUpdate",
        "body": [
        "shouldComponentUpdate(nextProps, nextState) {",
        "    ${1}",
        "}"
        ]
    }
}
