{
    "snip": {
        "prefix": "snip",
        "description": "snip",
        "body": [
        "snippet ${1:trigger} \"${2:description}\"",
        "    ${0:${TM_SELECTED_TEXT}}"
        ]
    },
    "v": {
        "prefix": "v",
        "description": "v",
        "body": [
        "{TM_SELECTED_TEXT}"
        ]
    },
    "$": {
        "prefix": "$",
        "description": "$",
        "body": [
        "${${1:1}:${0:text}}"        ]
    }
}
