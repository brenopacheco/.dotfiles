{
    "ts-import": {
        "prefix": "imp",
        "description": "import ... from '...'",
        "body": [
            "import ${1:*} from '${2:...}'"
        ]
    },
    "ts-fun": {
        "prefix": "fun",
        "description": "function ...(...){...}",
        "body": [
        "function ${1:function_name}(${2:args}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-afun": {
        "prefix": "afun",
        "description": "(...) => {...}",
        "body": [
        "(${1:args}) => {",
        "\t$0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-cfun": {
        "prefix": "cfun",
        "description": "const fun(...) => {...}",
        "body": [
        "const ${1:fun} = () => {",
        "\treturn (",
        "\t\t${0:${TM_SELECTED_TEXT}}",
        "\t)",
        "}"
        ]
    },
    "ts-if": {
        "prefix": "if",
        "description": "if (...) {...}",
        "body": [
        "if (${1:true}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-ife": {
        "prefix": "ife",
        "description": "if (...) {...} else {...}",
        "body": [
        "if (${1:true}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} else {",
        "    ${2}",
        "}"
        ]
    },
    "ts-else": {
        "prefix": "else",
        "description": "else {...}",
        "body": [
        "else {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-switch": {
        "prefix": "switch",
        "description": "switch",
        "body": [
        "switch (${1:expression}) {",
        "    case '${3:case}':",
        "        ${4}",
        "        break;",
        "    ${0}",
        "    default:",
        "        ${2}",
        "}"
        ]
    },
    "ts-case": {
        "prefix": "case",
        "description": "case 'xyz': ... break",
        "body": [
        "case '${1:case}':",
        "    ${0:${TM_SELECTED_TEXT}}",
        "    break;"
        ]
    },
    "ts-try": {
        "prefix": "try",
        "description": "try { ... } catch(e) { ... }",
        "body": [
        "try {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} catch (${1:e}) {",
        "    ${2:/* handle error */}",
        "}"
        ]
    },
    "ts-tryf": {
        "prefix": "tryf",
        "description": "try { ... } catch(e) { ... } finally { ... }",
        "body": [
        "try {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} catch (${1:e}) {",
        "    ${2:/* handle error */}",
        "} finally {",
        "    ${3:/* be executed regardless of the try / catch result*/}",
        "}"
        ]
    },
    "ts-throw": {
        "prefix": "terr",
        "description": "terr",
        "body": [
        "throw new Error('${1:error message}')"
        ]
    },
    "ts-ret": {
        "prefix": "ret",
        "description": "return ...",
        "body": [
        "return ${0:result};"
        ]
    },
    "ts-for": {
        "prefix": "for",
        "description": "for (...) {...}",
        "body": [
        "for (${1}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-fori": {
        "prefix": "fori",
        "description": "reversed for (...) {...}",
        "body": [
        "for (let ${1:i} = ${2:0}; $1 >= ${3:count}; $1--) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-forr": {
        "prefix": "forr",
        "description": "for (let prop of object}) { ... }",
        "body": [
        "for (let ${1:prop} of ${2:object}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-while": {
        "prefix": "wh",
        "description": "(condition) { ... }",
        "body": [
        "while (${1:/* condition */}) {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-dowhile": {
        "prefix": "dowhile",
        "description": "do { ... } while (condition)",
        "body": [
        "do {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "} while (${1:/* condition */});"
        ]
    },
    "ts-const": {
        "prefix": "const",
        "description": "const",
        "body": [
        "const ${1} = ${0};"
        ]
    },
    "ts-let": {
        "prefix": "let",
        "description": "let",
        "body": [
        "let ${1} = ${0};"
        ]
    },
    "ts-symbol": {
        "prefix": "symbol",
        "description": "Symbol(...)",
        "body": [
        "Symbol('${0}');"
        ]
    },
    "ts-export": {
        "prefix": "export",
        "description": "ed",
        "body": [
        "export default ${0}"
        ]
    },
    "ts-class": {
        "prefix": "class-ts",
        "description": "class {...}",
        "body": [
        "class ${1} {",
        "    ${0:${TM_SELECTED_TEXT}}",
        "}"
        ]
    },
    "ts-ctor": {
        "prefix": "ctor",
        "description": "constructor(...) {...}",
        "body": [
        "constructor(${1:props}) {${0:${TM_SELECTED_TEXT}}}"
        ]
    },
    "ts-cl": {
        "prefix": "cl",
        "description": "console.log",
        "body": [
        "console.log(${0:${TM_SELECTED_TEXT}});"
        ]
    },
    "ts-cd": {
        "prefix": "cd",
        "description": "console.debug",
        "body": [
        "console.debug(${0});"
        ]
    },
    "ts-ce": {
        "prefix": "ce",
        "description": "console.error",
        "body": [
        "console.error(${0});"
        ]
    },
    "ts-cw": {
        "prefix": "cw",
        "description": "console.warn",
        "body": [
        "console.warn(${0});"
        ]
    },
    "ts-ci": {
        "prefix": "ci",
        "description": "console.info",
        "body": [
        "console.info(${0});"
        ]
    },
    "ts-ct": {
        "prefix": "ct",
        "description": "console.trace",
        "body": [
        "console.trace(${0:label});"
        ]
    },
    "ts-ca": {
        "prefix": "ca",
        "description": "console.assert",
        "body": [
        "console.assert(${1:expression}, ${0:obj});"
        ]
    },
    "ts-cc": {
        "prefix": "cc",
        "description": "console.clear",
        "body": [
        "console.clear();"
        ]
    }
}
