[user]
    email = 1180005@isep.ipp.pt
    name = Breno Pacheco
[credential]
    helper = store
[mergetool]
    prompt = false
[merge]
    tool = nvimmerge
[mergetool "nvimmerge"]
    cmd = "nvim -f -c \"Gvdiffsplit!\" \"$MERGED\""
[difftool]
    prompt = false
[diff]
    tool = nvimdiff
[difftool "nvimdiff"]
    cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[log]
    date = relative
[alias]
    graph = !git log \"$@\" --oneline --graph --branches --remotes --date=short
